# DocuAgent v3 — Root Environment Variables
# Copy: cp .env.example .env  then fill in real values
# NEVER commit the filled .env file!

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=docuagent
# Local dev URL (Docker overrides this to use the 'postgres' service name)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docuagent

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Qdrant ───────────────────────────────────────────────────
# Local dev URL (Docker overrides this to http://qdrant:6333)
QDRANT_URL=http://localhost:6333

# ── n8n ──────────────────────────────────────────────────────
# Local dev URL (Docker overrides this to http://n8n:5678)
N8N_BASE_URL=http://localhost:5678
N8N_PASSWORD=
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=
WEBHOOK_URL=http://localhost:5678/
N8N_LABEL_WEBHOOK=http://localhost:5678/webhook/gmail-label-sync
N8N_CALENDAR_WEBHOOK=http://n8n:5678/webhook/calendar-create
# Optional: enables the frontend "Szinkronizálás" button to trigger WF4 manually
N8N_CALENDAR_SYNC_WEBHOOK=http://n8n:5678/webhook/calendar-sync-trigger
# n8n basic auth (used by docker-compose n8n service)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
# n8n internal settings
EXECUTIONS_PROCESS=main
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
# n8n nyilvános URL (böngészőből elérhető)
VITE_N8N_PUBLIC_URL=http://localhost:5678

# ── App ──────────────────────────────────────────────────────
COMPANY_NAME=Agentify Kft.
PORT=8000
CONFIDENCE_THRESHOLD=0.70

# ── Security ─────────────────────────────────────────────────
# REQUIRED IN PRODUCTION — generate with: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_API_KEY=
# REQUIRED IN PRODUCTION — set to your actual domain, NOT *
ALLOWED_ORIGINS=http://localhost:3000
# REDIS URL for arq worker queue
REDIS_URL=redis://redis:6379

# ── Human-in-the-loop ────────────────────────────────────────
# Human-review küldési webhook (n8n-be mutasson)
N8N_SEND_REPLY_WEBHOOK=http://localhost:5678/webhook/send-reply

# ── JWT ──────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=480

# ── Google (Gmail + Sheets) ───────────────────────────────────
GOOGLE_SHEET_ID=
REPORT_EMAIL=

# ── Slack (optional) ─────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Upload security ──────────────────────────────────────────
MAX_UPLOAD_MB=20

# ── RAG / Fallback ────────────────────────────────────────────
# If RAG confidence falls below this threshold → send template reply (0.0-1.0)
RAG_FALLBACK_THRESHOLD=0.45
FALLBACK_REPLY_HU=Köszönjük megkeresését! Utánanézünk és hamarosan visszajelzünk Önnek.
FALLBACK_REPLY_EN=Thank you for reaching out! We will look into this and get back to you shortly.
FALLBACK_REPLY_DE=Vielen Dank für Ihre Anfrage! Wir werden uns darum kümmern und uns bald bei Ihnen melden.
