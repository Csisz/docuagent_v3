# DocuAgent React Frontend — .env
# Vite csak VITE_ prefix-es változókat injektál a kódba

# Backend API URL (dev módban a proxy miatt nem kell, de build-nél igen)
VITE_API_URL=http://localhost:8000

# n8n nyilvános URL (böngészőből elérhető — dashboard n8n gombhoz)
VITE_N8N_PUBLIC_URL=http://localhost:5678

# Production-ban (Docker-ből elérve):
# VITE_API_URL=http://backend:8000
