# DocuAgent React Frontend — .env
# Vite csak VITE_ prefix-es változókat injektál a kódba

# Backend API URL (dev módban a proxy miatt nem kell, de build-nél igen)
VITE_API_URL=http://localhost:8000

# n8n nyilvános URL — böngészőből elérhető URL az "n8n megnyitása" gombok linkjéhez.
# FONTOS: Ezt a frontend olvassa, nem a backend!
# - Dev:        http://localhost:5678
# - Production: https://n8n.yourcompany.com (ha van reverse proxy)
# Ha nincs megadva, a backend N8N_BASE_URL értéke lesz az alap (ami internal Docker URL lehet).
VITE_N8N_PUBLIC_URL=http://localhost:5678

# Production-ban (Docker-ből elérve):
# VITE_API_URL=http://backend:8000
