<!DOCTYPE html>
<html lang="hu" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DocuAgent Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
/* ── THEMES ─────────────────────────────────────────────── */
[data-theme="dark"] {
  --bg:#0d0d0d;--bg1:#141414;--bg2:#1a1a1a;--bg3:#212121;
  --sb:#141414;--sb-b:rgba(255,255,255,.07);
  --brd:rgba(255,255,255,.08);--brd2:rgba(255,255,255,.14);
  --t:#fff;--t2:#a8a8a8;--t3:#5c5c5c;
  --acc:#ff6d5a;--acc2:#ea4b35;--acc-bg:rgba(255,109,90,.1);--acc-bd:rgba(255,109,90,.25);
  --grn:#22c55e;--grn-bg:rgba(34,197,94,.1);--grn-bd:rgba(34,197,94,.2);
  --red:#ef4444;--red-bg:rgba(239,68,68,.1);--red-bd:rgba(239,68,68,.2);
  --amb:#f59e0b;--amb-bg:rgba(245,158,11,.1);--amb-bd:rgba(245,158,11,.2);
  --blu:#3b82f6;--blu-bg:rgba(59,130,246,.1);--blu-bd:rgba(59,130,246,.2);
  --sh:none;--sh2:0 4px 20px rgba(0,0,0,.4);--card:#1a1a1a;--inp:#212121;
  --r:8px;--r2:12px;
}
[data-theme="light"] {
  --bg:#f0f4f8;--bg1:#fff;--bg2:#fff;--bg3:#f7fafc;
  --sb:#1a2332;--sb-b:rgba(255,255,255,.07);
  --brd:#e2e8f0;--brd2:#cbd5e1;
  --t:#0f172a;--t2:#475569;--t3:#94a3b8;
  --acc:#2563eb;--acc2:#1e40af;--acc-bg:#eff6ff;--acc-bd:#bfdbfe;
  --grn:#15803d;--grn-bg:#f0fdf4;--grn-bd:#bbf7d0;
  --red:#dc2626;--red-bg:#fef2f2;--red-bd:#fecaca;
  --amb:#d97706;--amb-bg:#fffbeb;--amb-bd:#fde68a;
  --blu:#2563eb;--blu-bg:#eff6ff;--blu-bd:#bfdbfe;
  --sh:0 1px 3px rgba(0,0,0,.08);--sh2:0 4px 16px rgba(0,0,0,.10);--card:#fff;--inp:#f7fafc;
  --r:8px;--r2:10px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--t);font-family:'IBM Plex Sans',sans-serif;font-size:14px;line-height:1.5;min-height:100vh;display:flex;transition:background .25s,color .25s}
[data-theme="dark"] body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.05) 1px,transparent 1px);background-size:24px 24px;pointer-events:none;z-index:0;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 40%,transparent 100%)}
.orb{display:none;position:fixed;border-radius:50%;filter:blur(130px);pointer-events:none;z-index:0;opacity:.08}
[data-theme="dark"] .orb{display:block}
.orb1{width:500px;height:500px;background:#ff6d5a;top:-100px;right:-100px;animation:orbF 18s ease-in-out infinite alternate}
.orb2{width:400px;height:400px;background:#8b5cf6;bottom:-80px;left:-80px;animation:orbF 22s ease-in-out infinite alternate-reverse}
@keyframes orbF{from{transform:translate(0,0)}to{transform:translate(50px,35px)}}
.shell{position:relative;z-index:1;display:flex;width:100%;min-height:100vh}

/* SIDEBAR */
aside{width:224px;flex-shrink:0;background:var(--sb);border-right:1px solid var(--sb-b);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;transition:background .25s}
.sb-logo{padding:18px 16px;border-bottom:1px solid var(--sb-b);display:flex;align-items:center;gap:10px}
.sb-mark{width:28px;height:28px;background:var(--acc);border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .25s}
.sb-mark svg{width:16px;height:16px}
.sb-name{font-size:14px;font-weight:600;color:white}
.sb-ver{font-size:9.5px;color:rgba(255,255,255,.3);font-family:'IBM Plex Mono',monospace}
nav{padding:8px 6px;flex:1;overflow-y:auto}
.ns{font-size:9px;color:rgba(255,255,255,.25);text-transform:uppercase;letter-spacing:.14em;padding:10px 10px 4px;font-family:'IBM Plex Mono',monospace}
.ni{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:var(--r);font-size:13px;color:rgba(255,255,255,.5);cursor:pointer;transition:all .12s;margin-bottom:1px;text-decoration:none;user-select:none}
.ni:hover{background:rgba(255,255,255,.06);color:rgba(255,255,255,.85)}
.ni.act{background:var(--acc-bg);color:var(--acc);font-weight:500}
[data-theme="light"] .ni.act{border-left:2px solid var(--acc);padding-left:8px}
.ni-ico{width:14px;height:14px;flex-shrink:0}
.ni-ico svg{width:14px;height:14px;display:block}
.nb{margin-left:auto;background:var(--red);color:white;font-size:10px;padding:1px 6px;border-radius:100px;font-family:'IBM Plex Mono',monospace;line-height:1.4}

/* THEME TOGGLE */
.theme-wrap{padding:10px 16px;border-top:1px solid var(--sb-b);display:flex;align-items:center;justify-content:space-between}
.th-label{font-size:11px;color:rgba(255,255,255,.35);font-family:'IBM Plex Mono',monospace;display:flex;align-items:center;gap:5px}
.tog-track{width:38px;height:20px;background:rgba(255,255,255,.12);border-radius:100px;cursor:pointer;position:relative;transition:background .2s;flex-shrink:0;border:1px solid rgba(255,255,255,.08)}
.tog-track.on{background:var(--acc)}
.tog-thumb{position:absolute;top:2px;left:2px;width:14px;height:14px;background:white;border-radius:50%;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.3)}
.tog-track.on .tog-thumb{transform:translateX(18px)}

.sb-foot{padding:10px 6px;border-top:1px solid var(--sb-b)}
.urow{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:var(--r);cursor:pointer;transition:background .12s}
.urow:hover{background:rgba(255,255,255,.05)}
.uav{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,var(--acc),#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:white;flex-shrink:0}
.uname{font-size:13px;color:rgba(255,255,255,.75);font-weight:500}
.urole{font-size:10px;color:rgba(255,255,255,.3)}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{background:var(--bg1);border-bottom:1px solid var(--brd);padding:0 22px;height:50px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;box-shadow:var(--sh);transition:background .25s,border-color .25s}
.bc{font-size:12px;color:var(--t3);display:flex;align-items:center;gap:6px}
.bc b{color:var(--t);font-weight:500}
.topbar-r{display:flex;align-items:center;gap:8px}
.lchip{display:flex;align-items:center;gap:5px;font-size:11px;font-family:'IBM Plex Mono',monospace;padding:3px 9px;border-radius:4px;border:1px solid}
.l-ok{color:var(--grn);background:var(--grn-bg);border-color:var(--grn-bd)}
.l-err{color:var(--red);background:var(--red-bg);border-color:var(--red-bd)}
.l-warn{color:var(--amb);background:var(--amb-bg);border-color:var(--amb-bd)}
.ld{width:5px;height:5px;border-radius:50%;background:currentColor;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.btn{padding:6px 14px;border-radius:var(--r);font-size:12px;font-weight:500;cursor:pointer;font-family:'IBM Plex Sans',sans-serif;transition:all .12s;border:none}
.btn-s{background:var(--bg3);border:1px solid var(--brd2);color:var(--t2);box-shadow:var(--sh)}
.btn-s:hover{border-color:var(--acc);color:var(--acc)}
.btn-p{background:var(--acc);color:white;font-weight:600}
.btn-p:hover{background:var(--acc2)}
.content{padding:22px 24px 60px;flex:1;overflow-y:auto}
.pg-title{font-size:18px;font-weight:600;letter-spacing:-.3px;color:var(--t);margin-bottom:2px}
.pg-sub{font-size:13px;color:var(--t3);margin-bottom:18px}

/* ALERTS */
.alert{display:flex;align-items:center;gap:10px;border-radius:var(--r);padding:9px 14px;margin-bottom:14px;font-size:13px;border:1px solid}
.al-w{background:var(--red-bg);border-color:var(--red-bd)}
.al-i{background:var(--blu-bg);border-color:var(--blu-bd)}
.al-msg{flex:1;color:var(--t2)}
.al-msg b{color:var(--red);font-weight:600}
.al-i .al-msg b{color:var(--blu)}
.al-x{cursor:pointer;color:var(--t3);font-size:15px}
.al-x:hover{color:var(--t)}

/* CARDS */
.card{background:var(--card);border:1px solid var(--brd);border-radius:var(--r2);padding:18px;box-shadow:var(--sh);transition:background .25s,border-color .25s,box-shadow .15s}
.card:hover{box-shadow:var(--sh2)}
.chead{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.ctitle{font-size:13.5px;font-weight:600;color:var(--t)}
.chip{font-size:10px;font-family:'IBM Plex Mono',monospace;font-weight:500;padding:2px 7px;border-radius:4px;border:1px solid;white-space:nowrap}
.c-acc{background:var(--acc-bg);color:var(--acc);border-color:var(--acc-bd)}
.c-grn{background:var(--grn-bg);color:var(--grn);border-color:var(--grn-bd)}
.c-amb{background:var(--amb-bg);color:var(--amb);border-color:var(--amb-bd)}
.c-blu{background:var(--blu-bg);color:var(--blu);border-color:var(--blu-bd)}
.c-red{background:var(--red-bg);color:var(--red);border-color:var(--red-bd)}

/* KPIs */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px}
.kpi{background:var(--card);border:1px solid var(--brd);border-radius:var(--r2);padding:16px 18px;box-shadow:var(--sh);position:relative;overflow:hidden;transition:all .15s}
.kpi:hover{box-shadow:var(--sh2);transform:translateY(-1px)}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.k0::before{background:var(--acc)}.k1::before{background:var(--grn)}.k2::before{background:var(--red)}.k3::before{background:var(--blu)}
.kpi-lbl{font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:7px;font-family:'IBM Plex Mono',monospace}
.kpi-val{font-size:30px;font-weight:700;letter-spacing:-1px;line-height:1;margin-bottom:5px}
.kv0{color:var(--acc)}.kv1{color:var(--grn)}.kv2{color:var(--red)}.kv3{color:var(--blu)}
.kpi-sub{font-size:11px;font-family:'IBM Plex Mono',monospace;color:var(--t3)}

/* STATUS BREAKDOWN */
.sb-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px}
.sb-card{background:var(--card);border:1px solid var(--brd);border-radius:var(--r);padding:11px 14px;display:flex;align-items:center;gap:8px;box-shadow:var(--sh);transition:background .25s}
.sb-badge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;font-family:'IBM Plex Mono',monospace;white-space:nowrap;flex-shrink:0}
.s-new{background:#e0f2fe;color:#0369a1}
.s-ai{background:var(--grn-bg);color:var(--grn)}
.s-att{background:var(--amb-bg);color:var(--amb)}
.s-cls{background:var(--bg3);color:var(--t3);border:1px solid var(--brd2)}
.sb-lbl{font-size:11px;color:var(--t3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sb-cnt{font-size:20px;font-weight:700;margin-left:auto;color:var(--t);flex-shrink:0}

/* CHARTS */
.charts-row{display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:14px}

/* BOTTOM */
.bot-row{display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:12px}
.act-item{display:flex;gap:9px;align-items:flex-start;padding:8px 0;border-bottom:1px solid var(--brd)}
.act-item:last-child{border:none}
.act-ico{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
.act-title{font-size:12.5px;color:var(--t);line-height:1.35}
.act-meta{font-size:10.5px;color:var(--t3);margin-top:1px;font-family:'IBM Plex Mono',monospace}

/* EMAIL TABLE */
.email-filters{display:flex;align-items:center;gap:7px;margin-bottom:12px;flex-wrap:wrap}
.fb{padding:4px 12px;border-radius:4px;font-size:11.5px;font-family:'IBM Plex Mono',monospace;cursor:pointer;border:1px solid var(--brd2);background:var(--card);color:var(--t2);transition:all .12s}
.fb:hover,.fb.act{background:var(--acc-bg);border-color:var(--acc-bd);color:var(--acc)}
.tbl-wrap{background:var(--card);border:1px solid var(--brd);border-radius:var(--r2);overflow:hidden;box-shadow:var(--sh)}
table{width:100%;border-collapse:collapse;font-size:13px}
thead th{background:var(--bg3);text-align:left;padding:9px 12px;font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;font-family:'IBM Plex Mono',monospace;border-bottom:1px solid var(--brd);white-space:nowrap}
tbody tr{border-bottom:1px solid var(--brd);transition:background .1s}
tbody tr:last-child{border:none}
tbody tr:hover{background:var(--bg3)}
tbody td{padding:9px 12px;color:var(--t2);vertical-align:middle}
.td-s{color:var(--t);font-weight:500;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.td-f{font-family:'IBM Plex Mono',monospace;font-size:11px;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.td-d{font-family:'IBM Plex Mono',monospace;font-size:11px;white-space:nowrap}
.badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;font-family:'IBM Plex Mono',monospace;white-space:nowrap}
.b-new{background:#e0f2fe;color:#0369a1}
.b-ai{background:var(--grn-bg);color:var(--grn)}
.b-att{background:var(--amb-bg);color:var(--amb)}
.b-cls{background:var(--bg3);color:var(--t3);border:1px solid var(--brd2)}
.b-lrn{background:var(--acc-bg);color:var(--acc);border:1px solid var(--acc-bd);font-size:9px;padding:1px 5px;margin-left:3px}
.urg-dot{width:5px;height:5px;border-radius:50%;background:var(--red);flex-shrink:0;display:inline-block;margin-right:3px;box-shadow:0 0 0 2px var(--red-bg)}
.conf-w{display:flex;align-items:center;gap:5px}
.conf-bar{width:44px;height:3px;background:var(--brd);border-radius:100px;overflow:hidden;flex-shrink:0}
.conf-f{height:100%;border-radius:100px}
.conf-txt{font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:var(--t3)}
.sel-st{padding:3px 8px;border-radius:4px;font-size:11px;font-family:'IBM Plex Mono',monospace;border:1px solid var(--brd2);background:var(--inp);color:var(--t2);cursor:pointer;outline:none;min-width:140px;transition:border-color .12s}
.sel-st:hover,.sel-st:focus{border-color:var(--acc)}
.exp-btn{background:none;border:none;cursor:pointer;color:var(--t3);font-size:13px;padding:2px 6px;border-radius:4px;transition:all .12s;font-family:'IBM Plex Sans',sans-serif;line-height:1}
.exp-btn:hover{background:var(--bg3);color:var(--t)}
.det-row td{padding:12px 16px;background:var(--acc-bg);border-top:1px solid var(--acc-bd)}
.det-grid{display:grid;grid-template-columns:1fr 2fr;gap:12px}
.dl-lbl{font-size:10px;font-family:'IBM Plex Mono',monospace;color:var(--t3);margin-bottom:3px;text-transform:uppercase;letter-spacing:.08em}
.dl-val{font-size:12.5px;color:var(--t2);white-space:pre-wrap;word-break:break-word;line-height:1.5}
.ai-box{background:var(--card);border:1px solid var(--acc-bd);border-radius:6px;padding:11px;margin-top:5px;font-size:12.5px;color:var(--t2);line-height:1.6}

/* AI PANEL */
.ai-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.ai-b{background:var(--bg3);border:1px solid var(--brd);border-radius:var(--r);padding:12px;transition:background .25s}
.ai-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;margin-bottom:8px;font-family:'IBM Plex Mono',monospace}
.al-r{color:var(--red)}.al-a{color:var(--amb)}.al-g{color:var(--grn)}
.ai-list{list-style:none}
.ai-list li{font-size:12px;color:var(--t2);padding:4px 0;border-bottom:1px solid var(--brd);display:flex;gap:6px;line-height:1.45}
.ai-list li:last-child{border:none}
.ai-list li::before{content:'›';font-size:12px;flex-shrink:0}
.li-r::before{color:var(--red)}.li-a::before{color:var(--amb)}.li-g::before{color:var(--grn)}
.ai-btn{background:none;border:1px solid var(--brd2);border-radius:5px;padding:3px 9px;font-size:11px;color:var(--t3);cursor:pointer;font-family:'IBM Plex Mono',monospace;display:flex;align-items:center;gap:4px;transition:all .12s}
.ai-btn:hover{border-color:var(--acc);color:var(--acc)}

/* DOCS */
.docs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.doc-card{background:var(--card);border:1px solid var(--brd);border-radius:var(--r);padding:14px;transition:all .15s}
.doc-card:hover{border-color:var(--brd2);box-shadow:var(--sh2)}
.doc-ext{font-family:'IBM Plex Mono',monospace;font-size:9.5px;font-weight:700;padding:3px 7px;border-radius:4px;display:inline-block;margin-bottom:8px}
.doc-name{font-size:13px;font-weight:500;color:var(--t);margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.doc-meta{font-size:11px;color:var(--t3);font-family:'IBM Plex Mono',monospace}

/* SYS */
.srow{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--brd);font-size:12.5px;color:var(--t2)}
.srow:last-child{border:none}
.sdot{width:6px;height:6px;border-radius:50%;flex-shrink:0;transition:background .25s}
.s-ok{background:var(--grn)}.s-err{background:var(--red)}.s-unk{background:var(--t3)}
.sval{margin-left:auto;font-size:10.5px;color:var(--t3);font-family:'IBM Plex Mono',monospace}

/* MISC */
.empty{text-align:center;padding:40px;color:var(--t3)}
.empty-ico{font-size:30px;margin-bottom:10px}
.skel{background:linear-gradient(90deg,var(--bg3) 25%,var(--brd2) 50%,var(--bg3) 75%);background-size:200% 100%;animation:sk 1.4s infinite;border-radius:3px;display:block}
@keyframes sk{0%{background-position:200% 0}100%{background-position:-200% 0}}
.spin{display:inline-block}
.spinning{animation:sp .7s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.kpi,.card{animation:fadeUp .35s ease both}
.kpi:nth-child(1){animation-delay:.04s}.kpi:nth-child(2){animation-delay:.08s}.kpi:nth-child(3){animation-delay:.12s}.kpi:nth-child(4){animation-delay:.16s}
.toast{position:fixed;bottom:20px;right:20px;background:var(--t);color:var(--bg);border-radius:var(--r);padding:10px 16px;font-size:13px;transform:translateY(60px);opacity:0;transition:all .3s;z-index:999;min-width:220px;max-width:340px;box-shadow:var(--sh2)}
.toast.show{transform:translateY(0);opacity:1}
.toast.ok{border-left:3px solid var(--grn)}
.toast.err{border-left:3px solid var(--red)}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:10px}
</style>
</head>
<body>
<div class="orb orb1"></div><div class="orb orb2"></div>
<div class="shell">

<!-- SIDEBAR -->
<aside>
  <div class="sb-logo">
    <div class="sb-mark"><svg viewBox="0 0 16 16" fill="none"><path d="M3 8h5M9 4l4 4-4 4" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="4.5" cy="8" r="1.5" fill="white"/></svg></div>
    <div><div class="sb-name">DocuAgent</div><div class="sb-ver">v3.1 · Enterprise</div></div>
  </div>
  <nav>
    <div class="ns">Főmenü</div>
    <a class="ni act" href="#" id="nav-dashboard" onclick="return nav('dashboard',this)">
      <span class="ni-ico"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="1" y="1" width="5" height="5" rx="1"/><rect x="8" y="1" width="5" height="5" rx="1"/><rect x="1" y="8" width="5" height="5" rx="1"/><rect x="8" y="8" width="5" height="5" rx="1"/></svg></span>
      Dashboard
    </a>
    <div class="ns">Emailek</div>
    <a class="ni" href="#" id="nav-emails" onclick="return nav('emails',this);loadEmails()">
      <span class="ni-ico"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="1" y="2" width="12" height="10" rx="1.2"/><path d="M1 5h12M5 2v3"/></svg></span>
      Összes email <span class="nb" id="nb-total">—</span>
    </a>
    <a class="ni" href="#" id="nav-attention" onclick="return navAttention()">
      <span class="ni-ico"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="7" cy="7" r="5.5"/><path d="M7 4.5v3M7 9.5v.5"/></svg></span>
      Figyelmet igényel <span class="nb" id="nb-att">—</span>
    </a>
    <div class="ns">Tartalom</div>
    <a class="ni" href="#" id="nav-docs" onclick="return nav('docs',this);loadDocs()">
      <span class="ni-ico"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 2h6l3 3v8a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/><path d="M9 2v3h3"/></svg></span>
      Dokumentumok
    </a>
    <div class="ns">Analitika</div>
    <a class="ni" href="#" id="nav-insights" onclick="return nav('insights',this);loadInsights()">
      <span class="ni-ico"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 10l3-4 2.5 2.5 2.5-4.5 2 2"/><path d="M1 13h12"/></svg></span>
      AI Insights
    </a>
  </nav>
  <div class="theme-wrap">
    <div class="th-label"><span>☀️</span><span id="th-lbl">Dark</span><span>🌙</span></div>
    <div class="tog-track" id="togTrack" onclick="toggleTheme()"><div class="tog-thumb"></div></div>
  </div>
  <div class="sb-foot">
    <div class="urow">
      <div class="uav">VH</div>
      <div><div class="uname" id="compName">Agentify Kft.</div><div class="urole">Admin</div></div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="bc"><span>DocuAgent</span><span>›</span><b id="pg-title">Dashboard</b></div>
    <div class="topbar-r">
      <div class="lchip l-warn" id="lchip"><span class="ld"></span><span id="ltxt">Betöltés...</span><span style="opacity:.5;margin-left:3px" id="ltime"></span></div>
      <button class="btn btn-s" onclick="exportCSV()">↓ Export</button>
      <button class="btn btn-p" onclick="document.getElementById('fileIn').click()">+ Dokumentum</button>
      <input type="file" id="fileIn" style="display:none" accept=".pdf,.docx,.xlsx,.txt,.csv,.md" onchange="quickUpload(this)">
    </div>
  </div>

  <div class="content">

    <!-- DASHBOARD -->
    <div id="sec-dashboard">
      <div class="pg-title">Intelligence Dashboard</div>
      <div class="pg-sub" id="pg-sub">Valós idejű AI aktivitás</div>
      <div id="alertsWrap"></div>
      <div class="kpi-row">
        <div class="kpi k0"><div class="kpi-lbl">Kezelt emailek</div><div class="kpi-val kv0" id="kv0">—</div><div class="kpi-sub" id="ks0">—</div></div>
        <div class="kpi k1"><div class="kpi-lbl">AI megválaszolta</div><div class="kpi-val kv1" id="kv1">—</div><div class="kpi-sub">automatikus</div></div>
        <div class="kpi k2"><div class="kpi-lbl">Figyelmet igényel</div><div class="kpi-val kv2" id="kv2">—</div><div class="kpi-sub" id="ks2">—</div></div>
        <div class="kpi k3"><div class="kpi-lbl">Átlag konfidencia</div><div class="kpi-val kv3" id="kv3">—</div><div class="kpi-sub">AI döntések</div></div>
      </div>
      <div class="sb-row">
        <div class="sb-card"><span class="sb-badge s-new">NEW</span><span class="sb-lbl">Feldolgozásra vár</span><span class="sb-cnt" id="cnt-new">—</span></div>
        <div class="sb-card"><span class="sb-badge s-ai">AI_ANSWERED</span><span class="sb-lbl">AI válaszolt</span><span class="sb-cnt" id="cnt-ai">—</span></div>
        <div class="sb-card"><span class="sb-badge s-att">NEEDS_ATTENTION</span><span class="sb-lbl">Emberi beavatkozás</span><span class="sb-cnt" id="cnt-att">—</span></div>
        <div class="sb-card"><span class="sb-badge s-cls">CLOSED</span><span class="sb-lbl">Lezárva</span><span class="sb-cnt" id="cnt-cls">—</span></div>
      </div>
      <div class="charts-row">
        <div class="card"><div class="chead"><div class="ctitle">Email aktivitás — 7 nap</div><span class="chip c-acc">Live</span></div><div style="height:180px;position:relative"><canvas id="timeChart"></canvas></div></div>
        <div class="card"><div class="chead"><div class="ctitle">Kategóriák</div></div><div style="height:180px;position:relative"><canvas id="pieChart"></canvas></div></div>
      </div>
      <div class="card" style="margin-bottom:14px">
        <div class="chead">
          <div class="ctitle">AI Elemzés</div>
          <div style="display:flex;align-items:center;gap:8px">
            <span style="font-size:10.5px;color:var(--t3);font-family:'IBM Plex Mono',monospace" id="aiTs">—</span>
            <button class="ai-btn" onclick="loadInsightsInline()"><span class="spin" id="aiSpin">↻</span> Frissítés</button>
          </div>
        </div>
        <div class="ai-grid" id="aiGrid">
          <div class="ai-b"><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px"></span></div>
          <div class="ai-b"><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px"></span></div>
          <div class="ai-b"><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px"></span></div>
        </div>
      </div>
      <div class="bot-row">
        <div class="card"><div class="chead"><div class="ctitle">Legutóbbi aktivitás</div><span class="chip c-grn">Élő</span></div><div id="actFeed"><span class="skel" style="height:12px;margin-bottom:7px"></span><span class="skel" style="height:12px"></span></div></div>
        <div class="card"><div class="chead"><div class="ctitle">Dokumentumok</div><span class="chip c-blu" id="docCnt">—</span></div><div id="docMini"></div></div>
        <div class="card">
          <div class="chead"><div class="ctitle">Rendszer</div></div>
          <div>
            <div class="srow"><span class="sdot s-unk" id="d-pg"></span>PostgreSQL<span class="sval" id="v-pg">—</span></div>
            <div class="srow"><span class="sdot s-unk" id="d-qdrant"></span>Qdrant<span class="sval" id="v-qdrant">—</span></div>
            <div class="srow"><span class="sdot s-unk" id="d-n8n"></span>n8n<span class="sval" id="v-n8n">—</span></div>
            <div class="srow"><span class="sdot s-unk" id="d-openai"></span>OpenAI<span class="sval" id="v-openai">—</span></div>
            <div class="srow"><span class="sdot s-unk" id="d-be"></span>Backend<span class="sval" id="v-be">—</span></div>
          </div>
          <div style="margin-top:12px;display:flex;gap:6px">
            <button class="btn btn-s" style="font-size:11px" onclick="window.open('http://localhost:5678','_blank')">n8n ↗</button>
            <button class="btn btn-s" style="font-size:11px" onclick="loadAll()">↻ Szinkron</button>
          </div>
        </div>
      </div>
    </div>

    <!-- EMAILS -->
    <div id="sec-emails" style="display:none">
      <div class="pg-title">Email kezelés</div>
      <div class="pg-sub">Státusz szerkesztés · Human-in-the-loop tanulás · <span style="color:var(--acc)">🧠 LEARNED badge = AI tanult ebből</span></div>
      <div class="email-filters">
        <span style="font-size:11px;color:var(--t3);font-family:'IBM Plex Mono',monospace">Szűrő:</span>
        <button class="fb act" id="fb-all" onclick="filterStatus(null)">Összes</button>
        <span style="color:var(--brd2)">|</span>
        <button class="fb" id="fb-NEW"             onclick="filterStatus('NEW')">NEW</button>
        <button class="fb" id="fb-AI_ANSWERED"     onclick="filterStatus('AI_ANSWERED')">AI_ANSWERED</button>
        <button class="fb" id="fb-NEEDS_ATTENTION" onclick="filterStatus('NEEDS_ATTENTION')">NEEDS_ATTENTION</button>
        <button class="fb" id="fb-CLOSED"          onclick="filterStatus('CLOSED')">CLOSED</button>
        <div style="margin-left:auto;display:flex;align-items:center;gap:8px">
          <span style="font-size:12px;color:var(--t3)" id="emailCount">—</span>
          <button class="btn btn-s" style="font-size:11px" onclick="loadEmails()">↻</button>
        </div>
      </div>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th style="width:26px"></th><th>Tárgy</th><th>Feladó</th><th>Kategória</th><th>Státusz</th><th>Konfidencia</th><th>Dátum</th><th>Módosítás (→ tanulás)</th></tr></thead>
          <tbody id="emailTbody"><tr><td colspan="8" style="text-align:center;padding:24px;color:var(--t3)">Betöltés...</td></tr></tbody>
        </table>
      </div>
    </div>

    <!-- DOCS -->
    <div id="sec-docs" style="display:none">
      <div class="pg-title">Dokumentumok</div>
      <div class="pg-sub" id="docs-sub">Feltöltött és Qdrant-ba indexelt dokumentumok</div>
      <div style="margin-bottom:16px">
        <button class="btn btn-p" onclick="document.getElementById('fileIn').click()">+ Dokumentum feltöltése</button>
        <span style="font-size:12px;color:var(--t3);margin-left:10px">PDF, DOCX, XLSX, TXT · max 20MB</span>
      </div>
      <div class="docs-grid" id="docsGrid"><div style="color:var(--t3);font-size:13px;padding:20px">Betöltés...</div></div>
    </div>

    <!-- INSIGHTS -->
    <div id="sec-insights" style="display:none">
      <div class="pg-title">AI Insights</div>
      <div class="pg-sub">Mesterséges intelligencia elemzés · utolsó 7 nap</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px">
        <div class="card"><div class="kpi-lbl">Tanulási korrekciók</div><div class="kpi-val kv0" id="ins-fb">—</div><div class="kpi-sub">feedback bejegyzés</div></div>
        <div class="card"><div class="kpi-lbl">Átlag konfidencia</div><div class="kpi-val kv1" id="ins-conf">—%</div><div class="kpi-sub">AI döntések minősége</div></div>
        <div class="card"><div class="kpi-lbl">Lezárt esetek</div><div class="kpi-val kv3" id="ins-cls">—</div><div class="kpi-sub">resolved</div></div>
      </div>
      <div class="card">
        <div class="chead"><div class="ctitle">Részletes AI elemzés</div><button class="ai-btn" onclick="loadInsights()"><span class="spin" id="insSpin">↻</span> Frissítés</button></div>
        <div class="ai-grid" id="insGrid">
          <div class="ai-b"><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px"></span></div>
          <div class="ai-b"><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px"></span></div>
          <div class="ai-b"><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px;margin-bottom:5px"></span><span class="skel" style="height:10px"></span></div>
        </div>
      </div>
    </div>

  </div>
</div>
</div><!-- /shell -->
<div class="toast" id="toast"></div>

<script>
const API = 'http://localhost:8000';
let S = { data:null, emails:[], emailFilter:null, charts:{}, theme:'dark' };

// THEME
function initTheme() {
  const t = localStorage.getItem('da-theme') || 'dark';
  applyTheme(t, false);
}
function applyTheme(t, save=true) {
  S.theme = t;
  document.documentElement.setAttribute('data-theme', t);
  const tr = document.getElementById('togTrack');
  const lb = document.getElementById('th-lbl');
  if (t === 'light') { tr.classList.add('on'); lb.textContent = 'Light'; }
  else               { tr.classList.remove('on'); lb.textContent = 'Dark'; }
  if (save) localStorage.setItem('da-theme', t);
  if (S.data) { try { renderCharts(S.data.charts); } catch {} }
  Chart.defaults.color = t === 'dark' ? '#5c5c5c' : '#94a3b8';
}
function toggleTheme() { applyTheme(S.theme === 'dark' ? 'light' : 'dark'); }

// NAV
function nav(sec, el) {
  document.querySelectorAll('[id^="sec-"]').forEach(s => s.style.display = 'none');
  document.getElementById('sec-' + sec).style.display = 'block';
  document.querySelectorAll('.ni').forEach(n => n.classList.remove('act'));
  if (el) el.classList.add('act');
  const titles = {dashboard:'Dashboard',emails:'Email kezelés',docs:'Dokumentumok',insights:'AI Insights'};
  document.getElementById('pg-title').textContent = titles[sec] || sec;
  // Trigger load
  if (sec === 'docs')     setTimeout(loadDocs, 0);
  if (sec === 'insights') setTimeout(loadInsights, 0);
  if (sec === 'emails')   setTimeout(loadEmails, 0);
  return false;
}
function navAttention() {
  nav('emails', document.getElementById('nav-attention'));
  setTimeout(() => filterStatus('NEEDS_ATTENTION'), 50);
  return false;
}

// TOAST
function toast(m, type='ok', ms=3500) {
  const t = document.getElementById('toast');
  t.textContent = m; t.className = `toast show ${type}`;
  setTimeout(() => t.classList.remove('show'), ms);
}

// LIVE CHIP
function setLive(type, text, time='') {
  const c = document.getElementById('lchip');
  c.className = `lchip l-${type}`;
  document.getElementById('ltxt').textContent = text;
  document.getElementById('ltime').textContent = time ? '· '+time : '';
}

// LOAD ALL
async function loadAll() {
  await Promise.all([loadDashboard(), checkHealth(), loadInsightsInline()]);
}

// DASHBOARD
async function loadDashboard() {
  setLive('warn', 'Betöltés...');
  try {
    const r = await fetch(`${API}/api/dashboard`, { signal: AbortSignal.timeout(8000) });
    if (!r.ok) throw new Error('HTTP '+r.status);
    const d = await r.json(); S.data = d;
    renderDash(d);
    setLive('ok', 'Live', new Date().toLocaleTimeString('hu-HU',{hour:'2-digit',minute:'2-digit'}));
    if (d.meta?.company) {
      document.getElementById('compName').textContent = d.meta.company;
      document.getElementById('pg-sub').textContent = `Valós idejű AI aktivitás · ${d.meta.company}`;
    }
    setTimeout(loadDashboard, 60000);
  } catch(e) { setLive('err','Backend offline'); renderMock(); }
}

function renderDash(d) {
  try { renderAlerts(d.alerts||[]); } catch {}
  try { renderKPIs(d.kpis, d.status_breakdown); } catch {}
  try { renderCharts(d.charts); } catch {}
  try { renderActivity(d.activity||[]); } catch {}
  try { renderDocMini(d.documents||[]); } catch {}
  document.getElementById('nb-total').textContent = d.kpis?.emails?.value || 0;
  document.getElementById('nb-att').textContent   = d.status_breakdown?.NEEDS_ATTENTION || 0;
}

function renderAlerts(alerts) {
  const c = document.getElementById('alertsWrap'); c.innerHTML = '';
  alerts.forEach(a => {
    const d = document.createElement('div');
    d.className = `alert al-${a.type==='warn'?'w':'i'}`;
    d.innerHTML = `<span>${a.type==='warn'?'⚠':'ℹ'}</span><div class="al-msg">${a.message}</div><span class="al-x" onclick="this.parentElement.remove()">✕</span>`;
    c.appendChild(d);
  });
}

function cu(id, end, sfx='') {
  const el = document.getElementById(id); if(!el) return; el.innerHTML = '';
  const t0 = performance.now();
  const f = n => { const p=Math.min((n-t0)/700,1); el.textContent=Math.round(p*p*(2-p)*end)+sfx; if(p<1)requestAnimationFrame(f); };
  requestAnimationFrame(f);
}

function renderKPIs(k, sb) {
  cu('kv0', k.emails?.value||0);
  cu('kv1', k.ai_answered?.value||0);
  cu('kv2', k.needs_attention?.value||0);
  cu('kv3', k.avg_confidence?.value||0, '%');
  const fb = k.feedback_total?.value || 0;
  document.getElementById('ks0').textContent = `${fb} feedback tárolt`;
  document.getElementById('ks2').textContent = fb > 0 ? `tanul ${fb} mintából` : 'nincs tanulás még';
  document.getElementById('cnt-new').textContent = sb?.NEW||0;
  document.getElementById('cnt-ai').textContent  = sb?.AI_ANSWERED||0;
  document.getElementById('cnt-att').textContent = sb?.NEEDS_ATTENTION||0;
  document.getElementById('cnt-cls').textContent = sb?.CLOSED||0;
}

// CHARTS
Chart.defaults.font.family = "'IBM Plex Mono', monospace";
Chart.defaults.font.size   = 10.5;

function gCol() {
  const cs = getComputedStyle(document.documentElement);
  return { acc:cs.getPropertyValue('--acc').trim(), red:cs.getPropertyValue('--red').trim(), amb:cs.getPropertyValue('--amb').trim(), t3:cs.getPropertyValue('--t3').trim(), brd:cs.getPropertyValue('--brd').trim() };
}

function renderCharts(c) {
  ['time','pie'].forEach(k=>{if(S.charts[k]){S.charts[k].destroy();delete S.charts[k];}});
  const col = gCol();
  const tl  = c?.timeline||{};
  const lb  = tl.labels?.length ? tl.labels : ['Nincs adat'];
  const em  = tl.emails?.length ? tl.emails : [0];
  const cp  = tl.complaints?.length ? tl.complaints : [0];

  S.charts.time = new Chart(document.getElementById('timeChart'),{type:'bar',
    data:{labels:lb,datasets:[
      {label:'Összes',data:em,backgroundColor:col.acc+'25',borderColor:col.acc+'88',borderWidth:1.5,borderRadius:4},
      {label:'Figyelmet',data:cp,type:'line',tension:.4,fill:true,backgroundColor:col.amb+'15',borderColor:col.amb,borderWidth:1.5,pointRadius:3,pointBackgroundColor:col.amb}
    ]},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      plugins:{legend:{labels:{boxWidth:8,padding:12,color:col.t3}}},
      scales:{x:{grid:{color:col.brd},ticks:{color:col.t3}},y:{grid:{color:col.brd},ticks:{color:col.t3,stepSize:1},beginAtZero:true}}}
  });

  const cat = c?.category||{};
  S.charts.pie = new Chart(document.getElementById('pieChart'),{type:'doughnut',
    data:{labels:['Panasz','Érdeklődés','Egyéb'],datasets:[{
      data:[cat.complaint||0,cat.inquiry||0,cat.other||0],
      backgroundColor:[col.red+'b0',col.acc+'b0',col.t3+'80'],
      borderColor:[col.red,col.acc,col.t3],borderWidth:1.5,hoverOffset:5
    }]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'65%',plugins:{legend:{position:'bottom',labels:{boxWidth:8,padding:9,color:col.t3}}}}
  });
}

const aIco={alert:['⚠','var(--amb-bg)'],doc:['◻','var(--blu-bg)'],email:['✉','var(--acc-bg)'],ok:['✓','var(--grn-bg)']};
function renderActivity(items) {
  const af=document.getElementById('actFeed'); af.innerHTML='';
  if(!items.length){af.innerHTML='<div style="color:var(--t3);font-size:13px;padding:6px 0">Még nincs aktivitás</div>';return;}
  items.forEach(a=>{
    const[ico,bg]=aIco[a.type]||['•','var(--bg3)'];
    const cStr = a.confidence>0 ? `<span style="font-family:\'IBM Plex Mono\',monospace;font-size:10px;color:var(--t3);margin-left:4px">${a.confidence}%</span>` : '';
    af.innerHTML+=`<div class="act-item"><div class="act-ico" style="background:${bg}">${ico}</div><div style="flex:1"><div class="act-title">${a.title}${cStr}</div><div class="act-meta">${a.meta}</div></div></div>`;
  });
}

const eC={docx:{bg:'rgba(59,130,246,.12)',c:'#3b82f6'},pdf:{bg:'rgba(239,68,68,.12)',c:'#ef4444'},xlsx:{bg:'rgba(16,185,129,.12)',c:'#10b981'}};
function renderDocMini(docs) {
  const dl=document.getElementById('docMini'); dl.innerHTML='';
  document.getElementById('docCnt').textContent=docs.length+' db';
  if(!docs.length){dl.innerHTML='<div style="color:var(--t3);font-size:13px">Nincs dokumentum</div>';return;}
  docs.slice(0,5).forEach(d=>{
    const c=eC[d.ext]||{bg:'var(--bg3)',c:'var(--t3)'};
    dl.innerHTML+=`<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--brd)"><div style="font-size:9px;font-weight:700;padding:2px 5px;border-radius:3px;background:${c.bg};color:${c.c};font-family:'IBM Plex Mono',monospace;width:34px;text-align:center">${(d.ext||'?').toUpperCase()}</div><div style="font-size:12.5px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--t)">${d.filename}</div><div style="font-size:10.5px;color:var(--t3);font-family:'IBM Plex Mono',monospace">${d.size_kb}KB</div></div>`;
  });
}

// AI INLINE
async function loadInsightsInline() {
  const sp=document.getElementById('aiSpin'); sp.classList.add('spinning');
  document.getElementById('aiTs').textContent='Betöltés...';
  try {
    const r=await fetch(`${API}/api/ai-insights`,{signal:AbortSignal.timeout(20000)});
    if(!r.ok) throw new Error('HTTP '+r.status);
    const d=await r.json();
    renderAIGrid(document.getElementById('aiGrid'),d.ai);
    document.getElementById('aiTs').textContent=new Date(d.generated_at).toLocaleString('hu-HU');
  } catch(e){renderAIGrid(document.getElementById('aiGrid'),{problems:['AI nem elérhető: '+e.message],trends:[],recommendations:[]});}
  finally{sp.classList.remove('spinning');}
}
function renderAIGrid(c,ai){
  c.innerHTML=`
    <div class="ai-b"><div class="ai-lbl al-r">Azonosított problémák</div><ul class="ai-list">${(ai.problems||[]).map(t=>`<li class="li-r">${t}</li>`).join('')||'<li style="color:var(--t3)">Nincs adat</li>'}</ul></div>
    <div class="ai-b"><div class="ai-lbl al-a">Észlelt trendek</div><ul class="ai-list">${(ai.trends||[]).map(t=>`<li class="li-a">${t}</li>`).join('')||'<li style="color:var(--t3)">Nincs adat</li>'}</ul></div>
    <div class="ai-b"><div class="ai-lbl al-g">Ajánlott teendők</div><ul class="ai-list">${(ai.recommendations||[]).map(t=>`<li class="li-g">${t}</li>`).join('')||'<li style="color:var(--t3)">Nincs adat</li>'}</ul></div>`;
}

// HEALTH
async function checkHealth(){
  try{
    const r=await fetch(`${API}/api/health`,{signal:AbortSignal.timeout(4000)});
    const h=await r.json();
    sd('pg',h.db?.ok,h.db?.ok?'Csatlakozva':'Offline');
    sd('qdrant',h.qdrant?.ok,h.qdrant?.ok?h.qdrant.vectors+' v':'Offline');
    sd('n8n',h.n8n?.ok,h.n8n?.ok?'Aktív':'Offline');
    sd('openai',h.openai?.configured,h.openai?.configured?'OK':'Key hiányzik');
    sd('be',true,'Online v'+(h.version||'?'));
    if(h.company) document.getElementById('compName').textContent=h.company;
  }catch{sd('be',false,'Offline');}
}
function sd(k,ok,l){
  const d=document.getElementById('d-'+k),v=document.getElementById('v-'+k);
  if(d)d.className='sdot '+(ok?'s-ok':'s-err');
  if(v)v.textContent=l;
}

// EMAIL TABLE
async function loadEmails(filter){
  const f=filter!==undefined?filter:S.emailFilter;
  const url=f?`${API}/api/emails?status=${f}&limit=50`:`${API}/api/emails?limit=50`;
  const tb=document.getElementById('emailTbody');
  tb.innerHTML='<tr><td colspan="8" style="text-align:center;padding:20px;color:var(--t3)">Betöltés...</td></tr>';
  try{
    const r=await fetch(url,{signal:AbortSignal.timeout(8000)});
    const d=await r.json(); S.emails=d.emails||[];
    document.getElementById('emailCount').textContent=`${S.emails.length} / ${d.total}`;
    renderEmailTable(S.emails);
  }catch{
    tb.innerHTML='<tr><td colspan="8"><div class="empty"><div class="empty-ico">⚠</div><div>Backend nem elérhető (localhost:8000)</div></div></td></tr>';
  }
}

function filterStatus(s){
  S.emailFilter=s;
  document.querySelectorAll('.fb').forEach(b=>b.classList.remove('act'));
  (document.getElementById('fb-'+s)||document.getElementById('fb-all')).classList.add('act');
  loadEmails(s);
}

function renderEmailTable(emails){
  const tb=document.getElementById('emailTbody');
  if(!emails.length){tb.innerHTML='<tr><td colspan="8"><div class="empty"><div class="empty-ico">✉</div><div>Nincs email ebben a kategóriában</div></div></td></tr>';return;}
  tb.innerHTML=emails.map(e=>{
    const sb={NEW:'<span class="badge b-new">NEW</span>',AI_ANSWERED:'<span class="badge b-ai">✓ AI</span>',NEEDS_ATTENTION:'<span class="badge b-att">⚠ FIGYELJ</span>',CLOSED:'<span class="badge b-cls">CLOSED</span>'}[e.status]||`<span class="badge">${e.status}</span>`;
    let aiD={};try{aiD=typeof e.ai_decision==='string'?JSON.parse(e.ai_decision):e.ai_decision||{};}catch{}
    const lrn=aiD.learned_override?'<span class="badge b-lrn">🧠 LEARNED</span>':'';
    const catC={complaint:'var(--red)',inquiry:'var(--blu)',other:'var(--t3)'}[e.category]||'var(--t3)';
    const cf=e.confidence||0;
    const cfC=cf>=.7?'var(--grn)':cf>=.4?'var(--amb)':'var(--red)';
    const dt=e.created_at?new Date(e.created_at).toLocaleString('hu-HU',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}):'—';
    const urg=e.urgent?'<span class="urg-dot"></span>':'';
    const aiDecStr=JSON.stringify(aiD,null,2);
    return `<tr>
      <td><button class="exp-btn" onclick="togRow('dr-${e.id}',this)">▸</button></td>
      <td class="td-s">${urg}${e.subject||'(nincs tárgy)'} ${lrn}</td>
      <td class="td-f">${e.sender||'—'}</td>
      <td><span style="font-size:11px;font-family:'IBM Plex Mono',monospace;color:${catC}">${e.category||'—'}</span></td>
      <td>${sb}</td>
      <td><div class="conf-w"><div class="conf-bar"><div class="conf-f" style="width:${Math.round(cf*100)}%;background:${cfC}"></div></div><span class="conf-txt">${Math.round(cf*100)}%</span></div></td>
      <td class="td-d">${dt}</td>
      <td><select class="sel-st" onchange="updateStatus('${e.id}','${e.status}',this.value,this)">
        <option value="NEW" ${e.status==='NEW'?'selected':''}>NEW</option>
        <option value="AI_ANSWERED" ${e.status==='AI_ANSWERED'?'selected':''}>AI_ANSWERED</option>
        <option value="NEEDS_ATTENTION" ${e.status==='NEEDS_ATTENTION'?'selected':''}>NEEDS_ATTENTION</option>
        <option value="CLOSED" ${e.status==='CLOSED'?'selected':''}>CLOSED</option>
      </select></td>
    </tr>
    <tr id="dr-${e.id}" style="display:none"><td colspan="8">
      <div class="det-grid">
        <div><div class="dl-lbl">Feladó</div><div class="dl-val">${e.sender||'—'}</div>
          <div class="dl-lbl" style="margin-top:10px">AI döntés JSON</div>
          <div class="dl-val" style="font-family:'IBM Plex Mono',monospace;font-size:11px">${aiDecStr}</div>
        </div>
        <div><div class="dl-lbl">AI válasz</div>
          <div class="ai-box">${e.ai_response||'<span style="color:var(--t3)">Nincs AI válasz (NEEDS_ATTENTION → emberi kezelés)</span>'}</div>
        </div>
      </div>
    </td></tr>`;
  }).join('');
}

function togRow(id,btn){const r=document.getElementById(id);const o=r.style.display!=='none';r.style.display=o?'none':'table-row';btn.textContent=o?'▸':'▾';}

async function updateStatus(id,old,newS,sel){
  if(old===newS)return;
  try{
    const r=await fetch(`${API}/api/emails/${id}/status`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:newS,note:''})});
    if(!r.ok)throw new Error('HTTP '+r.status);
    const d=await r.json();
    const lrn=d.learning_stored?' · 🧠 tanulás elmentve':'';
    toast(`✓ ${old} → ${newS}${lrn}`,'ok');
    const e=S.emails.find(x=>x.id===id);if(e)e.status=newS;
    loadDashboard();
  }catch(e){toast(`Hiba: ${e.message}`,'err');sel.value=old;}
}

// DOCS
async function loadDocs(){
  const grid=document.getElementById('docsGrid');
  grid.innerHTML='<div style="color:var(--t3);font-size:13px;padding:20px">Betöltés...</div>';
  try{
    const r=await fetch(`${API}/api/dashboard`,{signal:AbortSignal.timeout(8000)});
    const d=await r.json();
    const docs=d.documents||[];
    document.getElementById('docs-sub').textContent=`${docs.length} dokumentum · Qdrant: ${d.meta?.qdrant_vectors||0} vektor indexelve`;
    if(!docs.length){grid.innerHTML='<div class="empty"><div class="empty-ico">📄</div><div>Még nincs feltöltött dokumentum<br><span style="font-size:12px">Kattints a + Dokumentum gombra</span></div></div>';return;}
    grid.innerHTML=docs.map(d=>{
      const c=eC[d.ext]||{bg:'var(--bg3)',c:'var(--t3)'};
      return `<div class="doc-card"><div class="doc-ext" style="background:${c.bg};color:${c.c}">${(d.ext||'?').toUpperCase()}</div><div class="doc-name" title="${d.filename}">${d.filename}</div><div class="doc-meta">${d.uploader||'—'} · ${d.size_kb}KB · ${d.lang} · ${d.date}</div><div style="margin-top:6px"><span class="chip c-blu" style="font-size:10px">${d.tag}</span></div></div>`;
    }).join('');
  }catch{grid.innerHTML='<div class="empty"><div class="empty-ico">⚠</div><div>Backend nem elérhető</div></div>';}
}

// INSIGHTS
async function loadInsights(){
  const sp=document.getElementById('insSpin');sp.classList.add('spinning');
  try{
    const[dr,ir]=await Promise.all([
      fetch(`${API}/api/dashboard`),
      fetch(`${API}/api/ai-insights`,{signal:AbortSignal.timeout(20000)})
    ]);
    const dd=await dr.json();
    cu('ins-fb',dd.kpis?.feedback_total?.value||0);
    document.getElementById('ins-conf').textContent=(dd.kpis?.avg_confidence?.value||0)+'%';
    cu('ins-cls',dd.status_breakdown?.CLOSED||0);
    const id=await ir.json();
    renderAIGrid(document.getElementById('insGrid'),id.ai);
  }catch(e){renderAIGrid(document.getElementById('insGrid'),{problems:['Hiba: '+e.message],trends:[],recommendations:[]});}
  finally{sp.classList.remove('spinning');}
}

// UPLOAD
async function quickUpload(input){
  const file=input.files[0];if(!file)return;
  const fd=new FormData();fd.append('file',file);fd.append('uploader_name',document.getElementById('compName').textContent);fd.append('tag','general');
  try{
    toast(`Feltöltés: ${file.name}...`);
    const r=await fetch(`${API}/api/upload`,{method:'POST',body:fd,signal:AbortSignal.timeout(60000)});
    if(!r.ok)throw new Error('HTTP '+r.status);
    const d=await r.json();
    toast(`✓ ${d.filename} (${d.size_kb}KB · Qdrant: ${d.qdrant?'✓':'—'})`,'ok');
    loadDashboard();
    if(document.getElementById('sec-docs').style.display!=='none')loadDocs();
  }catch(e){toast(`Feltöltés hiba: ${e.message}`,'err');}
  input.value='';
}

// EXPORT
function exportCSV(){
  if(!S.emails.length){toast('Nyisd meg az Email nézetet először','err');return;}
  const rows=[['ID','Tárgy','Feladó','Kategória','Státusz','Konfidencia','Dátum'],...S.emails.map(e=>[e.id,'"'+(e.subject||'').replace(/"/g,'""')+'"',e.sender,e.category,e.status,e.confidence,e.created_at])];
  const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(rows.map(r=>r.join(',')).join('\n'));a.download='docuagent_'+new Date().toISOString().slice(0,10)+'.csv';a.click();
  toast('CSV letöltve','ok');
}

// MOCK
function renderMock(){
  renderAlerts([{type:'warn',message:'<b>Backend offline</b> — Indítsd el: <code>cd backend && python main.py</code>'}]);
  renderKPIs({emails:{value:8},ai_answered:{value:5},needs_attention:{value:2},avg_confidence:{value:72},feedback_total:{value:0}},{NEW:1,AI_ANSWERED:5,NEEDS_ATTENTION:2,CLOSED:0});
  renderCharts({timeline:{labels:['márc.18','márc.19','márc.20','márc.21','márc.22','márc.23'],emails:[2,1,1,2,1,1],complaints:[0,0,1,0,1,0]},category:{complaint:2,inquiry:4,other:2}});
  renderActivity([{type:'email',title:'Backend offline — Mock mód',meta:'localhost:8000',confidence:0}]);
  renderDocMini([]);
  renderAIGrid(document.getElementById('aiGrid'),{problems:['Backend offline (localhost:8000)'],trends:['Mock adatok'],recommendations:['cd backend && python main.py']});
}

// INIT
initTheme();
loadAll();
setInterval(checkHealth,30000);
</script>
</body>
</html>
